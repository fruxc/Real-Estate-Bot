{
  "name": "realestatebot",
  "version": "1.0.0",
  "description": "Autonomous WhatsApp Real Estate AI Agent for Mumbai property negotiation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "db:migrate": "psql $DATABASE_URL -f docker/postgres-init.sql",
    "db:seed": "ts-node scripts/seed.ts",
    "db:backup": "pg_dump $DATABASE_URL | gzip > backup_$(date +%Y%m%d).sql.gz"
  },
  "dependencies": {
    "whatsapp-web.js": "^1.25.0",
    "baileys": "^6.x",
    "axios": "^1.6.0",
    "openai": "^4.26.0",
    "anthropic": "^0.15.0",
    "youtube-transcript-api": "^1.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "ffmpeg-static": "^5.2.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "dotenv": "^16.3.0",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "bull": "^4.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.53.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
