# Environment Template (copy to .env.local)

# ════════════════════════════════════════════════════════════════
# WhatsApp Configuration
# ════════════════════════════════════════════════════════════════

WHATSAPP_CLIENT=baileys
WHATSAPP_SECRET=your-secret-key-here
SECONDARY_SIM_PORT=/dev/ttyUSB0

# ════════════════════════════════════════════════════════════════
# API Keys (CRITICAL - Never commit these)
# ════════════════════════════════════════════════════════════════

OPENAI_API_KEY=sk-xxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════
# Database (Supabase PostgreSQL)
# ════════════════════════════════════════════════════════════════

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ════════════════════════════════════════════════════════════════
# Vector Database (Pinecone)
# ════════════════════════════════════════════════════════════════

PINECONE_API_KEY=xxxx-xxxx-xxxx-xxxx
PINECONE_INDEX_NAME=realestatebot
PINECONE_ENVIRONMENT=us-east-1

# ════════════════════════════════════════════════════════════════
# Redis (Optional - for caching/sessions)
# ════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379

# ════════════════════════════════════════════════════════════════
# Environment & Logging
# ════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ════════════════════════════════════════════════════════════════
# Local Development
# ════════════════════════════════════════════════════════════════

LOCALHOST=true
MOCK_BROKERS=false
SKIP_WHATSAPP_CONNECTION=false

# ════════════════════════════════════════════════════════════════
# Autonomous Mode (March 22-31, 2026)
# ════════════════════════════════════════════════════════════════

AUTONOMOUS_MODE_ENABLED=false
AUTONOMOUS_MODE_START=2026-03-22
AUTONOMOUS_MODE_END=2026-03-31
AUTONOMOUS_MAX_TURNS_PER_DAY=5

# ════════════════════════════════════════════════════════════════
# Cost & Rate Limiting
# ════════════════════════════════════════════════════════════════

MAX_DAILY_COST_CENTS=2500
MAX_BROKER_COST_CENTS=1200
MAX_TURNS_PER_BROKER=10
MAX_API_CALLS_PER_BROKER=15
MAX_GLOBAL_COST_CENTS=2500

# ════════════════════════════════════════════════════════════════
# LLM Configuration
# ════════════════════════════════════════════════════════════════

LLM_PRIMARY_MODEL=claude-3-5-sonnet-20241022
LLM_FALLBACK_MODEL=claude-3-5-haiku-20241022
LLM_VISION_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ════════════════════════════════════════════════════════════════
# Email Configuration (for daily digest)
# ════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-specific-password
DIGEST_EMAIL=your-email@gmail.com
DIGEST_TIME=20:00

# ════════════════════════════════════════════════════════════════
# Security & PII
# ════════════════════════════════════════════════════════════════

PII_MASKING_ENABLED=true
INJECTION_DEFENSE_ENABLED=true
RATE_LIMITING_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# ════════════════════════════════════════════════════════════════
# Error Tracking (Optional)
# ════════════════════════════════════════════════════════════════

SENTRY_DSN=https://...
DATADOG_API_KEY=optional

# ════════════════════════════════════════════════════════════════
# Instructions for Setup:
# 1. Copy this file to .env.local
# 2. Replace all xxxx values with real credentials
# 3. Never commit .env.local to git
# 4. For local development, you can use placeholders
# 5. For production, use strong, unique values
# ════════════════════════════════════════════════════════════════
