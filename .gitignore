npm-shrinkwrap.json

# ========== RUNTIME & PROCESS FILES ==========
*.pid
*.seed
*.pid.lock
.nodemon.json
.prettierignore
pm2.log

# ========== VSCODE EXTENSIONS ==========
.vscode-test/
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# ========== MACOS/LINUX SPECIFIC ==========
