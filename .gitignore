# .gitignore - Real Estate Bot

# ========== CRITICAL: SECURITY & CREDENTIALS ==========
.env
.env.local
.env.*.local
.env.production.local
.env.test.local

# API Keys and Secrets (any file containing secrets)
secrets/
.secrets/
*.key
*.pem
*.p8
*.p12
.aws/
~/.aws/credentials

# WhatsApp Session Files (contains session data)
sessions/
.sessions/
auth_info_*.json
wa_auth_*.json

# ========== DEPENDENCIES ==========
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnp
.pnp.js

# ========== BUILD OUTPUT ==========
dist/
build/
out/
*.js
*.js.map
*.d.ts
*.d.ts.map
.tsbuildinfo
lib/
es/

# ========== DATABASE & DATA ==========
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sql
.postgres/
postgresql_data/

# ========== MEDIA & TEMP FILES ==========
/tmp/
/temp/
temp/
cache/
*.mp4
*.mp3
*.wav
*.mov
*.avi
*.flv
*.webm
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.pdf
uploads/
downloads/
media/

# ========== LOGS ==========
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log
.pnpm-debug.log*
pids/
*.pid

# ========== IDE & EDITOR ==========
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
*.iml
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.editorconfig

# ========== OS FILES ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini
.Thumbs.db

# ========== TESTING ==========
coverage/
.nyc_output/
.jest-cache/
.mocha-cache/
*.lcov
.coverage/
test-results/

# ========== CACHE & TEMPORARY ==========
.turbo/
.next/
.nuxt/
.cache/
.parcel-cache/
.eslintcache
.node_repl_history
.npm
.yarn/cache
.yarn/unplugged
